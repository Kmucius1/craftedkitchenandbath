# Database — Supabase (server-side service role; never exposed to the browser)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Admin dashboard (/admin/leads) login
ADMIN_PASSWORD=            # the password you type to sign in
ADMIN_SESSION_SECRET=      # long random string — the session cookie value

# Optional: email alert on every new lead (via Resend; sender domain must be verified)
RESEND_API_KEY=
LEAD_NOTIFY_EMAIL=         # where new-lead emails go (e.g. info@craftedkitchenandbath.com)
LEAD_NOTIFY_FROM="Crafted Leads <leads@craftedkitchenandbath.com>"

# AI chatbot (Crafty assistant) — OpenRouter API key
OPENROUTER_API_KEY=
